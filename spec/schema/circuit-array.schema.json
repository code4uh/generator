{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/circuit-array-spec.schema.json",
  "title": "Circuit Array Specification",
  "oneOf": [
    {
      "$ref": "#/$defs/CapArraySpec"
    },
    {
      "$ref": "#/$defs/ResArraySpec"
    }
  ],
  "$defs": {
    "CapArraySpec": {
      "type": "object",
      "required": [
        "version",
        "type",
        "inputs",
        "capabilities",
        "output"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "enum": [
            "0.1"
          ]
        },
        "type": {
          "const": "cap_array"
        },
        "inputs": {
          "$ref": "#/$defs/capArrayInputs"
        },
        "capabilities": {
          "$ref": "#/$defs/capArrayCapabilities"
        },
        "output": {
          "$ref": "#/$defs/output"
        }
      }
    },
    "ResArraySpec": {
      "type": "object",
      "required": [
        "version",
        "type",
        "inputs",
        "capabilities",
        "output"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "enum": [
            "0.1"
          ]
        },
        "type": {
          "const": "res_array"
        },
        "inputs": {
          "$ref": "#/$defs/resArrayInputs"
        },
        "capabilities": {
          "$ref": "#/$defs/resArrayCapabilities"
        },
        "output": {
          "$ref": "#/$defs/output"
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "libname",
        "cellname"
      ],
      "additionalProperties": false,
      "properties": {
        "libname": {
          "type": "string",
          "minLength": 1
        },
        "cellname": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "unsupportedOptionPolicy": {
      "type": "string",
      "enum": [
        "ignore",
        "ignore_with_warning",
        "error"
      ]
    },
    "routingLevel": {
      "type": "string",
      "enum": [
        "full",
        "partial",
        "none"
      ]
    },
    "boundarySize": {
      "type": "string",
      "enum": [
        "Unit",
        "Minimum"
      ]
    },
    "guardRingOptions": {
      "type": "object",
      "required": [
        "left",
        "right",
        "top",
        "bottom"
      ],
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "boolean"
        },
        "right": {
          "type": "boolean"
        },
        "top": {
          "type": "boolean"
        },
        "bottom": {
          "type": "boolean"
        }
      }
    },
    "routingOptions": {
      "type": "object",
      "required": [
        "nVias",
        "wireWidthHor",
        "wireWidthVer",
        "wireWidthPlus",
        "wireWidthMinus",
        "truncVerWires",
        "truncHorWires",
        "verWireAssignment",
        "horWireAssignment",
        "verShielding",
        "horShielding",
        "guardRingOptions",
        "addGuardRingSpacing"
      ],
      "additionalProperties": false,
      "properties": {
        "nVias": {
          "type": "integer",
          "minimum": 1
        },
        "wireWidthHor": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "wireWidthVer": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "wireWidthPlus": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "wireWidthMinus": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "truncVerWires": {
          "type": "boolean"
        },
        "truncHorWires": {
          "type": "boolean"
        },
        "verWireAssignment": {
          "type": "string",
          "enum": [
            "minus-plus",
            "separate-plus-minus"
          ]
        },
        "horWireAssignment": {
          "type": "string",
          "enum": [
            "all-bottom",
            "all-top",
            "symmetric",
            "separate-plus-minus"
          ]
        },
        "verShielding": {
          "type": "string",
          "enum": [
            "shield-pin",
            "Cdmy_n"
          ]
        },
        "horShielding": {
          "type": "string",
          "enum": [
            "device-bus",
            "plus-minus",
            "outer-edge"
          ]
        },
        "guardRingOptions": {
          "$ref": "#/$defs/guardRingOptions"
        },
        "addGuardRingSpacing": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "advanced": {
      "type": "object",
      "required": [
        "horDevSpacing",
        "verDevSpacing",
        "minHorDevBusSpacing",
        "minVerDevBusSpacing",
        "noRouting",
        "onlyVerticalWires",
        "omitHorizontalBus",
        "deleteFloatingWires",
        "wireSpaceHor",
        "wireSpaceVer"
      ],
      "additionalProperties": false,
      "properties": {
        "horDevSpacing": {
          "type": "number"
        },
        "verDevSpacing": {
          "type": "number"
        },
        "minHorDevBusSpacing": {
          "type": "number",
          "minimum": 0
        },
        "minVerDevBusSpacing": {
          "type": "number",
          "minimum": 0
        },
        "noRouting": {
          "type": "boolean"
        },
        "onlyVerticalWires": {
          "type": "boolean"
        },
        "omitHorizontalBus": {
          "type": "boolean"
        },
        "deleteFloatingWires": {
          "type": "boolean"
        },
        "wireSpaceHor": {
          "type": "number",
          "minimum": 0
        },
        "wireSpaceVer": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "capBoundaryCaps": {
      "type": "object",
      "required": [
        "left",
        "right",
        "top",
        "bottom",
        "boundary_size"
      ],
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "boolean"
        },
        "right": {
          "type": "boolean"
        },
        "top": {
          "type": "boolean"
        },
        "bottom": {
          "type": "boolean"
        },
        "boundary_size": {
          "$ref": "#/$defs/boundarySize"
        }
      }
    },
    "resBoundaryResistors": {
      "type": "object",
      "required": [
        "left",
        "right",
        "top",
        "bottom",
        "boundary_size"
      ],
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "boolean"
        },
        "right": {
          "type": "boolean"
        },
        "top": {
          "type": "boolean"
        },
        "bottom": {
          "type": "boolean"
        },
        "boundary_size": {
          "$ref": "#/$defs/boundarySize"
        }
      }
    },
    "capTopology": {
      "type": "object",
      "required": [
        "cap_list",
        "connection",
        "connectDummyCaps",
        "boundary_caps"
      ],
      "additionalProperties": false,
      "properties": {
        "cap_list": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "connection": {
          "type": "string",
          "enum": [
            "open",
            "shortPlusPins",
            "userDefined"
          ]
        },
        "plusConnected": {
          "type": "string",
          "minLength": 1
        },
        "connectDummyCaps": {
          "type": "string",
          "enum": [
            "open_floating",
            "open_shorted",
            "shorted_G1_p",
            "shorted_Cdmy_p",
            "Cdmy_p+Cdmy_n"
          ]
        },
        "boundary_caps": {
          "$ref": "#/$defs/capBoundaryCaps"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "connection": {
                "const": "userDefined"
              }
            }
          },
          "then": {
            "required": [
              "plusConnected"
            ]
          }
        }
      ]
    },
    "capPlacementPatternRow": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(C[1-9][0-9]*_[1-9][0-9]*|C0_[1-9][0-9]*)$"
      }
    },
    "capPlacement": {
      "type": "object",
      "required": [
        "rows",
        "algorithm",
        "pattern"
      ],
      "additionalProperties": false,
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "common_centroid",
            "side-by-side",
            "side-by-side-row-wise",
            "user"
          ]
        },
        "pattern": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/capPlacementPatternRow"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "algorithm": {
                "const": "user"
              }
            }
          },
          "then": {
            "properties": {
              "pattern": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "pattern": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "dummyCaps": {
      "type": "object",
      "required": [
        "naming_rule"
      ],
      "additionalProperties": false,
      "properties": {
        "naming_rule": {
          "type": "string",
          "const": "C0_<idx>"
        }
      }
    },
    "capArrayInputs": {
      "type": "object",
      "required": [
        "topology",
        "placement",
        "dummy_caps",
        "routing_options",
        "advanced"
      ],
      "additionalProperties": false,
      "properties": {
        "topology": {
          "$ref": "#/$defs/capTopology"
        },
        "placement": {
          "$ref": "#/$defs/capPlacement"
        },
        "dummy_caps": {
          "$ref": "#/$defs/dummyCaps"
        },
        "routing_options": {
          "$ref": "#/$defs/routingOptions"
        },
        "advanced": {
          "$ref": "#/$defs/advanced"
        }
      }
    },
    "capArrayCapabilities": {
      "type": "object",
      "required": [
        "placement",
        "routing",
        "advanced",
        "unsupported_option_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "placement": {
          "type": "object",
          "required": [
            "supported_algorithms",
            "pattern_supported"
          ],
          "additionalProperties": false,
          "properties": {
            "supported_algorithms": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "common_centroid",
                  "side-by-side",
                  "side-by-side-row-wise",
                  "user"
                ]
              }
            },
            "pattern_supported": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "routing": {
          "type": "object",
          "required": [
            "level"
          ],
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "partial",
                "none"
              ]
            }
          }
        },
        "advanced": {
          "type": "object",
          "required": [
            "level"
          ],
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "partial",
                "none"
              ]
            }
          }
        },
        "unsupported_option_policy": {
          "$ref": "#/$defs/unsupportedOptionPolicy"
        }
      }
    },
    "resTopology": {
      "type": "object",
      "required": [
        "res_list",
        "parallelResNo",
        "connectDummyRes",
        "boundary_resistors"
      ],
      "additionalProperties": false,
      "properties": {
        "res_list": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "parallelResNo": {
          "type": "integer",
          "minimum": 1
        },
        "connectDummyRes": {
          "type": "string",
          "enum": [
            "open_floating",
            "VSS"
          ]
        },
        "boundary_resistors": {
          "$ref": "#/$defs/resBoundaryResistors"
        }
      }
    },
    "resPlacement": {
      "type": "object",
      "required": [
        "algorithm",
        "pattern"
      ],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "side-by-side"
        },
        "pattern": {
          "type": "null"
        }
      }
    },
    "dummyResistors": {
      "type": "object",
      "required": [
        "naming_rule"
      ],
      "additionalProperties": false,
      "properties": {
        "naming_rule": {
          "type": "string",
          "const": "R0_<idx>"
        }
      }
    },
    "resArrayInputs": {
      "type": "object",
      "required": [
        "topology",
        "placement",
        "dummy_resistors",
        "routing_options",
        "advanced"
      ],
      "additionalProperties": false,
      "properties": {
        "topology": {
          "$ref": "#/$defs/resTopology"
        },
        "placement": {
          "$ref": "#/$defs/resPlacement"
        },
        "dummy_resistors": {
          "$ref": "#/$defs/dummyResistors"
        },
        "routing_options": {
          "$ref": "#/$defs/routingOptions"
        },
        "advanced": {
          "$ref": "#/$defs/advanced"
        }
      }
    },
    "resArrayCapabilities": {
      "type": "object",
      "required": [
        "placement",
        "routing",
        "advanced",
        "unsupported_option_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "placement": {
          "type": "object",
          "required": [
            "supported_algorithms",
            "pattern_supported"
          ],
          "additionalProperties": false,
          "properties": {
            "supported_algorithms": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "type": "string",
                "const": "side-by-side"
              }
            },
            "pattern_supported": {
              "type": "boolean",
              "const": false
            }
          }
        },
        "routing": {
          "type": "object",
          "required": [
            "level"
          ],
          "additionalProperties": false,
          "properties": {
            "level": {
              "$ref": "#/$defs/routingLevel"
            }
          }
        },
        "advanced": {
          "type": "object",
          "required": [
            "level",
            "supported_fields"
          ],
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "partial",
                "full",
                "none"
              ]
            },
            "supported_fields": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "horDevSpacing",
                  "verDevSpacing",
                  "minHorDevBusSpacing",
                  "minVerDevBusSpacing",
                  "noRouting",
                  "onlyVerticalWires",
                  "omitHorizontalBus",
                  "deleteFloatingWires",
                  "wireSpaceHor",
                  "wireSpaceVer"
                ]
              }
            }
          }
        },
        "unsupported_option_policy": {
          "$ref": "#/$defs/unsupportedOptionPolicy"
        }
      }
    }
  }
}
